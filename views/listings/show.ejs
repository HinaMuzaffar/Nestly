<% layout("/layouts/boilerplate")%>
<script>
    const map_token = "<%= process.env.MAP_TOKEN %>";
    const listing = <%- JSON.stringify(listing) %>;
</script>
<!-- Listing Title -->
<div class="row mt-3">
    <div class="col-12 col-md-8 offset-md-2 col-lg-6 offset-lg-3">
    <h3 class="text-center text-md-start"><%= listing.title %> </h3>
</div>
</div>
<!-- Listing Card -->
 <div class="row">
    <div class="card col-12 col-md-8 offset-md-2 col-lg-6 offset-lg-3 show-card listing-card">
        <div class="image-gallery-container">  <% listing.images.forEach(img => { %>
            <div class="image-wrapper">
             <img src="<%= img.url  %>" class="card-img-top show-img img-fluid" alt="listing_image">
             </div>
       <% })%></div>
      
        <div class="card-body">
            <p class="card-text"> <b>Owned By</b>
                <i> <%= listing.owner.username  %></i> </p>
            <p class="card-text"> <b>About this place </b> <br><%= listing.description %> </p>   
            <p class="card-text"><b>Category </b> <br> <%= listing.category %></p>
            <p class="card-text">  <b>Price</b><br> <%= listing.price.toLocaleString("en-US" , {style : "currency" , currency : "USD" , minimumFractionDigits : 0}) %> for 1 night</p>
            <p class="card-text"> <b>Location </b>  <br> <%= listing.location %> </p>
            <p class="card-text"> <b>Country</b> <br> <%= listing.country %> </p>
            <p class="card-text"> <b>Cancellation Policy</b> <br>  <%= listing.cancellationPolicy %>   </p>
        </div>
    </div>
</div>
<br>
<!-- Delete section for Owner -->
<%  if(currUser && listing.owner._id.equals(currUser._id)) { %>
<div class="btns d-flex flex-row  justify-content-start align-items-start gap-2 mt-3">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn">Edit</a>
    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
        <button class="btn btn-dark edit-btn">Delete</button>
       </form>
   </div>
<%  } %>
<!-- Booking Section -->
 <div class="row">
 <div class="col-12 col-md-8 offset-md-2 text-center mb-3">
<% if(currUser && !listing.owner._id.equals(currUser._id)) { %> 
<a href="/bookings/<%= listing._id %>/new" class="btn btn-primary px-4">Book Now</a>
    <% } %>
</div>
</div>
<!-- Review Section -->
 <div class="row mt-4 ">
   <div class="col-12 col-md-8 offset-md-2">
    <% if(currUser && !listing.owner._id.equals(currUser._id)) { %>
        <hr>
    <h4>Leave a Review</h4>
    <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
        <div class="mb-3">
            <label for="rating" class="form-label">Rating</label>
        <fieldset class="starability-slot">
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>
          </div>
        <div class="mb-3">
            <label for="comment" class="form-label">Comments</label>
            <textarea rows="5" id="comment" name="review[comment]" class="form-control" required></textarea>
            <div class="invalid-feedback">Please add some comments for review.</div>
        </div>
        <button class="btn btn-outline-dark">Submit</button>
    </form>
    <hr>
    <% } %>
    </div>
    </div>

    <!-- Display Reviews -->
    <%  if(listing.reviews.length > 0) {%>
    <div class="row mt-2">
          <div class="col-12 col-md-8 offset-md-2">
        <p><b>All Reviews</b></p>
     <% for(review of listing.reviews) { %>
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                <h5 class="card-title"> @<%= review.author.username %></h5>
                <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
                </div>
                <p class="card-text mb-2"> <%= review.comment %></p>
                <% if( currUser && currUser._id.equals(review.author._id)) { %>
            <form class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-sm btn-dark">Delete</button>
                <% } %>
            </form>
        </div>
        </div>
   <% } %>
    </div>
    <% } %>
</div>


<!-- Map Section -->
 <div class="row">
    <div class="col-12 col-md-8 offset-md-2 mb-3">
        <h3>Where you'll be</h3>
        <div class="map-responsive">
        <div id="map"></div>
        </div>
        </div>
</div>

<script src="/js/map.js"></script>